# Variables de entorno del panel (panel-pedidos).
# Copia este archivo a `.env.local` y rellena los valores reales.
# NUNCA subas el `.env`/`.env.local` real al repositorio.
#
# Las que empiezan por NEXT_PUBLIC_ se incluyen en el bundle del navegador
# (son públicas por diseño). Las que NO llevan ese prefijo viven solo en el
# servidor — NO poner aquí secretos con NEXT_PUBLIC_.

# --- Supabase (públicas; la seguridad real la dan las RLS policies) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Bot (server-side; NO usar NEXT_PUBLIC_) ---
# Misma clave que INTERNAL_API_KEY del bot. La usa /api/bot-proxy.
INTERNAL_API_KEY=
# URL pública del bot en Railway (opcional; hay fallback en el código).
BOT_URL=

# --- Sentry ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
